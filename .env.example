# Backend
DB_URL=jdbc:postgresql://localhost:5432/unicode_db
DB_USERNAME=postgres
DB_PASSWORD=change_me
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_ISSUER=unicode-academy
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_SQL_INIT_MODE=never
SPRING_SQL_INIT_ENCODING=UTF-8
SPRING_JPA_DEFER_DATASOURCE_INITIALIZATION=false
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_FORMAT_SQL=false

MAX_FILE_SIZE=10MB
MAX_REQUEST_SIZE=10MB

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_CONNECTION_TIMEOUT_MS=5000
SMTP_TIMEOUT_MS=5000
SMTP_WRITE_TIMEOUT_MS=5000

APP_MAIL_FROM=no-reply@example.com
APP_MAIL_ACCOUNT_TERMINATION_ENABLED=true
CHAT_RETENTION_HOURS=24
CHAT_RETENTION_CRON=0 0 * * * *
APP_CODE_EXECUTION_TIMEOUT_MS=6000
APP_CODE_EXECUTION_MAX_OUTPUT_BYTES=65536
APP_CODE_EXECUTION_MAX_CODE_LENGTH=20000
APP_CODE_EXECUTION_MAX_SQL_ROWS=60
LOG_LEVEL_SECURITY=INFO
LOG_LEVEL_DATASOURCE_INIT=INFO

# Frontend
VITE_API_URL=http://localhost:8080
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
